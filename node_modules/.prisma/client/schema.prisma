// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================
enum Role {
  ADMIN
  SELLER
  ACCOUNTANT
  USER
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum PriceType {
  RETAIL
  WHOLESALE
  PROMOTIONAL
  SPECIAL
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  DIGITAL
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
}

enum ExpenseType {
  FIXED
  VARIABLE
}

enum ProductStatus {
  ACTIVE
  PAUSED
  DISCONTINUED
  OUT_OF_STOCK
}

// ==================== MAIN MODELS ====================
model User {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  email          String          @unique
  password       String
  name           String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  sales          Sale[]
  purchaseOrders PurchaseOrder[]
  isVerified     Boolean         @default(false)
  tokens         Token[]

  // ── RELACIONES DEL SISTEMA FLEXIBLE ──
  dynamicObjects         DynamicObject[] @relation("DynamicObjectCreatedBy")
  dynamicRecordsAssigned DynamicRecord[] @relation("AssignedToUser")
  dynamicRecordsCreated  DynamicRecord[] @relation("RecordCreatedBy")
}

model Token {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  products      Product[]
  subCategories SubCategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  categoryId String    @db.ObjectId
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Supplier {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String?
  phone               String?
  address             String?
  state               String?
  city                String?
  numberStreet        String?
  paymentTerms        String?
  productsSupplied    String[]
  purchaseOrders      PurchaseOrder[]
  supplierEvaluations SupplierEvaluation[]
  rawMaterials        RawMaterial[]
  products            Product[]            @relation("SupplierProducts")
  packagingMaterials  PackagingMaterial[]  @relation("PackagingSupplier")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Warehouse {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  location       String
  stocks         Stock[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // ── RELACIÓN CON OBJETOS DINÁMICOS ──
  dynamicRecords DynamicRecord[] @relation("WarehouseLocation")
}

model Customer {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String?  @unique
  phone           String?
  purchaseHistory Sale[]
  loyaltyPoints   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== PRODUCT & MANUFACTURING ====================
model Product {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  sku           String       @unique
  categoryId    String       @db.ObjectId
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?      @db.ObjectId
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  supplierId    String?      @db.ObjectId
  supplier      Supplier?    @relation("SupplierProducts", fields: [supplierId], references: [id])
  images        String[]
  createdById   String       @db.ObjectId
  createdBy     User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  status          ProductStatus @default(ACTIVE) @map("status")
  statusChangedAt DateTime?     @map("status_changed_at")
  statusReason    String?       @map("status_reason")

  variants         Variant[]
  stock            Stock[]
  prices           Price[]
  customFields     CustomField[]
  purchaseOrders   PurchaseOrderProduct[]
  saleItems        SaleItem[]
  productMaterials ProductMaterial[]
  packaging        ProductPackaging[]     @relation("ProductPackaging")
}

// ==================== SISTEMA FLEXIBLE (Objetos Dinámicos) ====================
// Esto te permite crear "tablas" nuevas sin tocar Prisma nunca más

model DynamicObject {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String  @unique
  description String?
  icon        String?
  color       String? @default("#3b82f6")

  // Campos que va a tener este objeto (definidos por el usuario)
  fields Json // Ej: [{"name":"marca","type":"TEXT","required":true}, {"name":"potencia","type":"NUMBER"}, ...]

  records DynamicRecord[]

  createdById String @db.ObjectId
  createdBy   User   @relation("DynamicObjectCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicRecord {
  id       String        @id @default(auto()) @map("_id") @db.ObjectId
  objectId String        @db.ObjectId
  object   DynamicObject @relation(fields: [objectId], references: [id])

  // Los datos reales del registro (totalmente dinámico)
  data Json

  // Campos comunes útiles para cualquier objeto
  status       String  @default("ACTIVE") // ACTIVE, IN_USE, MAINTENANCE, RENTED, SOLD, etc.
  assignedToId String? @db.ObjectId
  assignedTo   User?   @relation("AssignedToUser", fields: [assignedToId], references: [id])

  // Ubicación (puede ser un warehouse o una dirección custom)
  locationId   String?    @db.ObjectId
  location     Warehouse? @relation("WarehouseLocation", fields: [locationId], references: [id])
  locationText String?

  value  Float? // valor de adquisición o alquiler
  images String[]

  createdById String @db.ObjectId
  createdBy   User   @relation("RecordCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([objectId])
  @@index([assignedToId])
}

// ==================== RAW MATERIALS & PACKAGING ====================
model RawMaterial {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  description       String?
  sku               String             @unique
  supplierId        String             @db.ObjectId
  supplier          Supplier           @relation(fields: [supplierId], references: [id])
  unitPrice         Float
  currency          String             @default("ARS")
  unitOfMeasure     String
  stockQuantity     Float
  lowStockThreshold Float?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  productMaterials  ProductMaterial[]
  priceHistory      RawMaterialPrice[]
}

model RawMaterialPrice {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  rawMaterialId String      @db.ObjectId
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  unitPrice     Float
  currency      String      @default("ARS")
  validFrom     DateTime    @default(now())
  validUntil    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProductMaterial {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  productId     String      @db.ObjectId
  product       Product     @relation(fields: [productId], references: [id])
  rawMaterialId String      @db.ObjectId
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  quantity      Float
  unitOfMeasure String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PackagingMaterial {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  sku              String             @unique
  supplierId       String             @db.ObjectId
  supplier         Supplier           @relation("PackagingSupplier", fields: [supplierId], references: [id])
  unitPrice        Float
  unitOfMeasure    String
  stockQuantity    Float
  productPackaging ProductPackaging[] @relation("ProductPackagingMaterials")
  createdAt        DateTime           @default(now())
}

model ProductPackaging {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  productId           String            @db.ObjectId
  product             Product           @relation("ProductPackaging", fields: [productId], references: [id])
  packagingMaterialId String            @db.ObjectId
  packagingMaterial   PackagingMaterial @relation("ProductPackagingMaterials", fields: [packagingMaterialId], references: [id])
  quantityPerUnit     Float
  createdAt           DateTime          @default(now())
}

// ==================== INVENTORY & SALES ====================
model Variant {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  productId  String     @db.ObjectId
  product    Product    @relation(fields: [productId], references: [id])
  name       String
  sku        String     @unique
  attributes Json
  stock      Stock[]
  prices     Price[]
  saleItems  SaleItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Stock {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  productId         String          @db.ObjectId
  product           Product         @relation(fields: [productId], references: [id])
  variantId         String?         @db.ObjectId
  variant           Variant?        @relation(fields: [variantId], references: [id])
  warehouseId       String          @db.ObjectId
  warehouse         Warehouse       @relation(fields: [warehouseId], references: [id])
  quantity          Int
  lowStockThreshold Int?
  expiryDate        DateTime?
  stockMovements    StockMovement[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model StockMovement {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  stockId     String       @db.ObjectId
  stock       Stock        @relation(fields: [stockId], references: [id])
  warehouseId String       @db.ObjectId
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  type        MovementType
  quantity    Int
  reason      String?
  createdAt   DateTime     @default(now())
}

model Price {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  productId  String    @db.ObjectId
  product    Product   @relation(fields: [productId], references: [id])
  variantId  String?   @db.ObjectId
  variant    Variant?  @relation(fields: [variantId], references: [id])
  type       PriceType
  amount     Float
  currency   String    @default("ARS")
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Sale {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @db.ObjectId
  user          User          @relation(fields: [userId], references: [id])
  customerId    String?       @db.ObjectId
  customer      Customer?     @relation(fields: [customerId], references: [id])
  saleDate      DateTime      @default(now())
  totalAmount   Float
  paymentMethod PaymentMethod
  status        SaleStatus
  items         SaleItem[]
  invoice       Invoice?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SaleItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  saleId    String   @db.ObjectId
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?  @db.ObjectId
  variant   Variant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Float

  // ── FLEXIBILIDAD EXTRA: ítems que no existen en el catálogo ──
  isAdHoc          Boolean @default(false)
  adHocName        String?
  adHocDescription String?
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  saleId        String   @unique @db.ObjectId
  sale          Sale     @relation(fields: [saleId], references: [id])
  invoiceNumber String   @unique
  issueDate     DateTime @default(now())
  totalAmount   Float
  taxAmount     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== PURCHASE & EXPENSES ====================
model PurchaseOrder {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  supplierId  String                 @db.ObjectId
  supplier    Supplier               @relation(fields: [supplierId], references: [id])
  createdById String                 @db.ObjectId
  createdBy   User                   @relation(fields: [createdById], references: [id])
  orderDate   DateTime               @default(now())
  status      OrderStatus
  totalAmount Float
  products    PurchaseOrderProduct[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model PurchaseOrderProduct {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId String        @db.ObjectId
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String        @db.ObjectId
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Float
}

model SupplierEvaluation {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  supplierId           String   @db.ObjectId
  supplier             Supplier @relation(fields: [supplierId], references: [id])
  deliveryTime         Int?
  qualityRating        Float?
  priceCompetitiveness Float?
  comments             String?
  createdAt            DateTime @default(now())
}

model ExpenseCategory {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String      @unique
  type      ExpenseType
  expenses  Expense[]
  createdAt DateTime    @default(now())
}

model Expense {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  categoryId        String          @db.ObjectId
  category          ExpenseCategory @relation(fields: [categoryId], references: [id])
  description       String
  amount            Float
  currency          String          @default("ARS")
  date              DateTime
  isRecurring       Boolean         @default(false)
  recurringInterval String?
  createdAt         DateTime        @default(now())
}

model CustomField {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  productId String    @db.ObjectId
  product   Product   @relation(fields: [productId], references: [id])
  name      String
  value     String
  type      FieldType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
